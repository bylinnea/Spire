<?xml version="1.0" encoding="utf-8"?>
<!--
    Restricts the app to HTTPS only, no plain HTTP allowed.
    Both PlantNet and Anthropic use HTTPS, so this is safe.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
