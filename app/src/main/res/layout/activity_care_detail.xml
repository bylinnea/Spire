<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/careDetailScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_cream">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="60dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingTop="52dp"
                android:paddingBottom="4dp"
                android:gravity="center_vertical">

            </LinearLayout>

            <!-- Title block -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingBottom="24dp">

                <!-- Plant name - small caps label -->
                <TextView
                    android:id="@+id/careDetailPlantName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/green_muted"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.16"
                    android:textAllCaps="true"
                    android:layout_marginBottom="2dp" />

                <!-- Care type - big title -->
                <TextView
                    android:id="@+id/careDetailTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="32sp"
                    android:textColor="@color/green_deep"
                    android:fontFamily="sans-serif-light" />

                <!-- Back Button  -->
                <TextView android:id="@+id/btnBack" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="← back"
                    android:textSize="13sp" android:textColor="@color/green_muted"
                    android:fontFamily="sans-serif-light" android:letterSpacing="0.04"
                    android:paddingTop="8dp" android:paddingBottom="32dp" />

            </LinearLayout>

            <!-- Schedule card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="20dp"
                    android:paddingHorizontal="20dp"
                    android:paddingBottom="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="schedule"
                        android:textSize="10sp"
                        android:textColor="@color/green_muted"
                        android:fontFamily="sans-serif"
                        android:letterSpacing="0.14"
                        android:textAllCaps="true"
                        android:layout_marginBottom="14dp" />

                    <!-- Interval row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="every"
                            android:textSize="13sp"
                            android:textColor="@color/text_hint"
                            android:fontFamily="sans-serif-light" />
                        <TextView
                            android:id="@+id/careDetailInterval"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <!-- Last done row -->
                    <LinearLayout
                        android:id="@+id/rowLastDone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="last done"
                            android:textSize="13sp"
                            android:textColor="@color/text_hint"
                            android:fontFamily="sans-serif-light" />
                        <TextView
                            android:id="@+id/careDetailLastDone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <!-- Next due row -->
                    <LinearLayout
                        android:id="@+id/rowNextDue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="next due"
                            android:textSize="13sp"
                            android:textColor="@color/text_hint"
                            android:fontFamily="sans-serif-light" />
                        <TextView
                            android:id="@+id/careDetailNextDue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                    <!-- Fertilizer type, only shown for fertilize care type -->
                    <LinearLayout
                        android:id="@+id/rowFertilizerType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp"
                        android:visibility="gone">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="type"
                            android:textSize="13sp"
                            android:textColor="@color/text_hint"
                            android:fontFamily="sans-serif-light" />
                        <TextView
                            android:id="@+id/careDetailFertilizerType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                    <!-- Fertilizer calculator toggle - shown only for fertilize type -->
                    <TextView
                        android:id="@+id/fertCalcTrigger"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="fertilizer calculator ↓"
                        android:textSize="12sp"
                        android:textColor="@color/green_forest"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.04"
                        android:paddingTop="16dp"
                        android:visibility="gone" />

                    <!-- Collapsible calculator inputs -->
                    <LinearLayout
                        android:id="@+id/fertCalcInputs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="bottle dose (ml per litre)"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginBottom="4dp" />
                        <EditText
                            android:id="@+id/inputBottleDose"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="e.g. 5"
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-light"
                            android:inputType="numberDecimal"
                            android:background="@drawable/input_underline"
                            android:paddingBottom="8dp"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="water you're using (litres)"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginBottom="4dp" />
                        <EditText
                            android:id="@+id/inputWaterAmount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="e.g. 0.5"
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-light"
                            android:inputType="numberDecimal"
                            android:background="@drawable/input_underline"
                            android:paddingBottom="8dp"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="N-P-K ratio (optional)"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginBottom="4dp" />
                        <EditText
                            android:id="@+id/inputNPK"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="e.g. 10-10-10"
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-light"
                            android:inputType="text"
                            android:background="@drawable/input_underline"
                            android:paddingBottom="8dp"
                            android:layout_marginBottom="20dp" />

                        <TextView
                            android:id="@+id/btnCalculate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="calculate"
                            android:textSize="13sp"
                            android:textColor="@color/green_forest"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.04"
                            android:gravity="center"
                            android:paddingVertical="12dp"
                            android:background="@drawable/btn_outline_green"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:id="@+id/fertCalcResult"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-light"
                            android:lineSpacingMultiplier="1.5"
                            android:visibility="gone" />

                    </LinearLayout>
                    <!-- Repotting calculator - only shown for repot care type -->
                    <TextView
                        android:id="@+id/repotCalcTrigger"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="pot size calculator ↓"
                        android:textSize="12sp"
                        android:textColor="@color/green_forest"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.04"
                        android:paddingTop="16dp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/repotCalcInputs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="current pot size"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="20dp">

                            <EditText
                                android:id="@+id/inputCurrentPotSize"
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:hint="e.g. 12"
                                android:textColorHint="@color/text_hint"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                android:fontFamily="sans-serif-light"
                                android:inputType="numberDecimal"
                                android:background="@drawable/input_underline"
                                android:paddingBottom="8dp" />

                            <TextView
                                android:id="@+id/repotCalcUnitLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="cm"
                                android:textSize="13sp"
                                android:textColor="@color/text_hint"
                                android:fontFamily="sans-serif-light"
                                android:layout_marginStart="8dp" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/repotCalcResult"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-light"
                            android:lineSpacingMultiplier="1.5"
                            android:visibility="gone" />

                    </LinearLayout>
                    <!-- Mark done button -->
                    <TextView
                        android:id="@+id/btnMarkDone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="mark done"
                        android:textSize="13sp"
                        android:textColor="@color/green_forest"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.04"
                        android:gravity="center"
                        android:paddingVertical="12dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/btn_outline_green" />
                    <!-- Skip repotting -->
                    <TextView
                        android:id="@+id/btnSkipRepot"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="skip repotting"
                        android:textSize="13sp"
                        android:textColor="@color/status_overdue_dot"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.04"
                        android:gravity="center"
                        android:paddingVertical="12dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/btn_outline_terracotta"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tip card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/tipCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/green_pale">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tipLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="tip"
                        android:textSize="10sp"
                        android:textColor="@color/green_muted"
                        android:fontFamily="sans-serif"
                        android:letterSpacing="0.14"
                        android:textAllCaps="true"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/careDetailTip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif-light"
                        android:lineSpacingMultiplier="1.5" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Log timeline card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="20dp"
                    android:paddingHorizontal="20dp"
                    android:paddingBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="history"
                        android:textSize="10sp"
                        android:textColor="@color/green_muted"
                        android:fontFamily="sans-serif"
                        android:letterSpacing="0.14"
                        android:textAllCaps="true"
                        android:layout_marginBottom="12dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/careDetailLogRecycler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <TextView
                        android:id="@+id/careDetailLogEmpty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="no history yet"
                        android:textSize="13sp"
                        android:textColor="@color/text_hint"
                        android:fontFamily="sans-serif-light"
                        android:layout_marginTop="4dp"
                        android:visibility="gone" />

                    <!-- Spacer -->
                    <View android:layout_width="match_parent" android:layout_height="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Top edge indicator -->
    <View
        android:id="@+id/edgeIndicatorTop"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:layout_gravity="top"
        android:background="@color/green_forest"
        android:alpha="0" />

    <!-- Bottom edge indicator -->
    <View
        android:id="@+id/edgeIndicatorBottom"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:layout_gravity="bottom"
        android:background="@color/green_forest"
        android:alpha="0" />

</FrameLayout>
