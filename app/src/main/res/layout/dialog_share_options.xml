<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/shareTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textColor="#6B8F6B"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.14"
        android:textAllCaps="true"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/btnInfoOnly"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="plant info only"
        android:textSize="14sp"
        android:textColor="#2A4A2A"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.04"
        android:gravity="center"
        android:paddingVertical="14dp"
        android:background="@drawable/btn_outline_green"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/btnWithLogs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="plant info + last 10 log entries"
        android:textSize="14sp"
        android:textColor="#2A4A2A"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.04"
        android:gravity="center"
        android:paddingVertical="14dp"
        android:background="@drawable/btn_outline_green" />

</LinearLayout>