<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/plantCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/bg_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="18dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">

        <!-- Photo / emoji -->
        <FrameLayout
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_marginEnd="16dp">

            <ImageView
                android:id="@+id/plantPhoto"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="Plant photo" />

            <TextView
                android:id="@+id/emojiBackground"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/circle_bg_sage" />

            <TextView
                android:id="@+id/statusIcon"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:gravity="center"
                android:text="🌿"
                android:textSize="26sp" />

        </FrameLayout>

        <!-- Right side -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/plantName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.01" />

            <TextView
                android:id="@+id/plantSchedule"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-light" />

            <!-- Watering status -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/statusDot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/circle_dot"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/lastWatered"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif-light" />

            </LinearLayout>

            <!-- Other due tasks -->
            <LinearLayout
                android:id="@+id/dueTasksRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/circle_dot_amber"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/dueTasksText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif-light" />

            </LinearLayout>

            <!-- Water button -->
            <TextView
                android:id="@+id/buttonWater"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="water now"
                android:textSize="12sp"
                android:textColor="@color/green_forest"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/btn_outline_green" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
