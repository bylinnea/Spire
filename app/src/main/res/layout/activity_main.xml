<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_cream">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="52dp"
        android:paddingBottom="0dp"
        android:background="@color/bg_cream">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="spire" android:textSize="11sp" android:textColor="@color/green_muted"
            android:fontFamily="sans-serif" android:letterSpacing="0.16" android:textAllCaps="true" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginTop="2dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="My Plants" android:textSize="32sp" android:textColor="@color/green_deep"
                android:fontFamily="sans-serif-light" android:letterSpacing="0.02" />
            <TextView android:id="@+id/btnPlantSitter"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✉" android:textSize="22sp" android:textColor="@color/green_muted"
                android:paddingStart="12dp" android:paddingBottom="4dp"
                android:contentDescription="Plant sitter" />
            <TextView android:id="@+id/btnGraveyard"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✝" android:textSize="22sp" android:textColor="@color/green_muted"
                android:paddingStart="12dp" android:paddingBottom="4dp"
                android:contentDescription="Graveyard" />
            <TextView android:id="@+id/btnSettings"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚙" android:textSize="22sp" android:textColor="@color/green_muted"
                android:paddingStart="12dp" android:paddingBottom="4dp"
                android:contentDescription="Settings" />
        </LinearLayout>

        <!-- Sort row: collapsed by default -->
        <LinearLayout
            android:id="@+id/sortRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <!-- "..." trigger pill - always visible -->
            <TextView
                android:id="@+id/pillTrigger"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="···"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:background="@drawable/pill_unselected"
                android:textColor="@color/green_muted" />

            <!-- Expanded pills -->
            <HorizontalScrollView
                android:id="@+id/pillsExpanded"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:visibility="gone"
                android:layout_marginStart="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">


                <TextView
                    android:id="@+id/pillName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="name"
                    android:textSize="12sp" android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.04"
                    android:paddingHorizontal="14dp" android:paddingVertical="6dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/pill_selected"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/pillNextDue"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="next due"
                    android:textSize="12sp" android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.04"
                    android:paddingHorizontal="14dp" android:paddingVertical="6dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/pill_unselected"
                    android:textColor="@color/green_muted" />

                <TextView
                    android:id="@+id/pillOverdue"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="most overdue"
                    android:textSize="12sp" android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.04"
                    android:paddingHorizontal="14dp" android:paddingVertical="6dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/pill_unselected"
                    android:textColor="@color/green_muted" />

                <TextView
                    android:id="@+id/pillByRoom"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:text="by room"
                    android:singleLine="true"
                    android:textSize="12sp" android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.04"
                    android:paddingHorizontal="14dp" android:paddingVertical="6dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/pill_unselected"
                    android:textColor="@color/green_muted" />
                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/green_pale" />

    </LinearLayout>

    <!-- Plant list -->
    <FrameLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="8dp"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            android:background="@color/bg_cream" />

        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🌱" android:textSize="48sp" android:layout_marginBottom="12dp" />
            <TextView android:id="@+id/emptyText" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="No plants yet"
                android:textSize="17sp" android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-light" android:layout_marginBottom="4dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="tap + to add your first" android:textSize="13sp"
                android:textColor="@color/text_secondary" android:fontFamily="sans-serif-light"
                android:letterSpacing="0.04" />
        </LinearLayout>

        <!-- FAB speed-dial group -->
        <LinearLayout
            android:id="@+id/fabMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="24dp"
            android:orientation="vertical"
            android:gravity="end">

            <!-- Mini action: scan QR -->
            <LinearLayout
                android:id="@+id/fabScanRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="scan QR"
                    android:textSize="12sp"
                    android:textColor="#2A4A2A"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/pill_unselected_v2"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:layout_marginEnd="10dp" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fabScan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/green_forest"
                    android:contentDescription="Scan QR"
                    app:srcCompat="@drawable/ic_qr_code"
                    app:fabSize="mini"
                    app:maxImageSize="18dp"
                    app:elevation="0dp"
                    app:pressedTranslationZ="0dp" />
            </LinearLayout>

            <!-- Mini action: add plant -->
            <LinearLayout
                android:id="@+id/fabAddRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="add plant"
                    android:textSize="12sp"
                    android:textColor="#2A4A2A"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/pill_unselected_v2"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:layout_marginEnd="10dp" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fabAdd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/green_forest"
                    android:contentDescription="Add plant"
                    app:srcCompat="@drawable/ic_edit"
                    app:fabSize="mini"
                    app:elevation="0dp"
                    app:pressedTranslationZ="0dp" />
            </LinearLayout>

            <!-- Main FAB -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/green_deep"
                android:contentDescription="Menu"
                app:srcCompat="@drawable/ic_add"
                app:elevation="0dp"
                app:pressedTranslationZ="0dp" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
